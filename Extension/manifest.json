{
  "manifest_version": 3,
  "name": "OrderDeck Chat Bridge",
  "version": "1.2.1",
  "description": "Forwards Instagram, TikTok, Facebook and YouTube Live chat to OrderDeck",
  "background": { "service_worker": "background.js" },
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.instagram.com/*",
    "*://*.tiktok.com/*",
    "*://*.facebook.com/*",
    "*://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["chat-bridge-core.js", "content-instagram.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.tiktok.com/*"],
      "js": ["chat-bridge-core.js", "content-tiktok.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["chat-bridge-core.js", "content-facebook.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.youtube.com/live_chat*"],
      "js": ["chat-bridge-core.js", "content-youtube.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": { "default_popup": "popup.html" }
}
