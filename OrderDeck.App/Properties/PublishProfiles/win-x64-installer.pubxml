<?xml version="1.0" encoding="utf-8"?>
<!--
  Self-contained x64 publish profile used by installer/build.ps1 to
  produce the binary tree the Inno Setup installer ships.

  Notes:
  - PublishSingleFile = false. Multi-file is friendlier for installers
    (cold-start latency without %TEMP%/.net unzip step) and lets the
    installer's compression compact better than a self-contained single
    .exe whose internal zip already eats the gain.
  - PublishReadyToRun = true. AOT-compiled assemblies cut WPF first-paint
    by 200-400 ms on cold launch — invisible after warm-up but matters
    on operator's "is this thing frozen?" first impression.
  - PublishTrimmed = false. WPF + reflection-heavy libraries (CommunityToolkit.
    Mvvm source-generators, SharpVectors SVG, Newtonsoft via Hangfire, etc.)
    have a long history of post-trim runtime breakage. ~50 MB savings
    don't justify the per-update QA cost.
  - PublishDir = ../../publish/. Relative to OrderDeck.App.csproj location,
    so dotnet publish dumps to repo-root/publish/, which the installer
    script picks up as Source: "..\publish\*".
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>true</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <!-- Relative to OrderDeck.App.csproj: one level up to repo root,
         then publish/. Inno Setup script expects publish at repo root
         (Source: "..\publish\*"). -->
    <PublishDir>..\publish\</PublishDir>
  </PropertyGroup>
</Project>
