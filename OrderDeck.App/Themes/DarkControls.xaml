<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <!--
        Implicit (key-less) styles applied across every Window in OrderDeck.App
        so child controls inherit the dark theme that the dialog backgrounds
        already establish (Background="#FF1A1A1A" Foreground="White"). Without
        these styles WPF falls back to the OS Aero theme — white TextBox /
        ComboBox / Label on a black panel, unreadable.

        Per-control overrides in individual XAML files still win — we only
        provide defaults for unstyled controls.
    -->

    <!-- Shared brushes -->
    <SolidColorBrush x:Key="OD.Bg.Surface"         Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="OD.Bg.Input"           Color="#FF2A2A2A"/>
    <SolidColorBrush x:Key="OD.Bg.InputHover"      Color="#FF333333"/>
    <SolidColorBrush x:Key="OD.Bg.InputDisabled"   Color="#FF222222"/>
    <SolidColorBrush x:Key="OD.Border.Input"       Color="#FF555555"/>
    <SolidColorBrush x:Key="OD.Border.InputHover"  Color="#FF888888"/>
    <SolidColorBrush x:Key="OD.Fg.Primary"         Color="White"/>
    <SolidColorBrush x:Key="OD.Fg.Muted"           Color="#FFAAAAAA"/>
    <SolidColorBrush x:Key="OD.Fg.Disabled"        Color="#FF666666"/>
    <SolidColorBrush x:Key="OD.Accent"             Color="#FF4A90E2"/>
    <SolidColorBrush x:Key="OD.Accent.Hover"       Color="#FF5BA0F2"/>
    <SolidColorBrush x:Key="OD.Selection"          Color="#FF3E5F8A"/>

    <!-- TextBox -->
    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Background"           Value="{StaticResource OD.Bg.Input}"/>
        <Setter Property="Foreground"           Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="CaretBrush"           Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="SelectionBrush"       Value="{StaticResource OD.Selection}"/>
        <Setter Property="BorderBrush"          Value="{StaticResource OD.Border.Input}"/>
        <Setter Property="BorderThickness"      Value="1"/>
        <Setter Property="Padding"              Value="6,4"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource OD.Border.InputHover}"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource OD.Accent}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{StaticResource OD.Bg.InputDisabled}"/>
                <Setter Property="Foreground" Value="{StaticResource OD.Fg.Disabled}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- PasswordBox uses the same look as TextBox -->
    <Style TargetType="{x:Type PasswordBox}">
        <Setter Property="Background"           Value="{StaticResource OD.Bg.Input}"/>
        <Setter Property="Foreground"           Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="CaretBrush"           Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="SelectionBrush"       Value="{StaticResource OD.Selection}"/>
        <Setter Property="BorderBrush"          Value="{StaticResource OD.Border.Input}"/>
        <Setter Property="BorderThickness"      Value="1"/>
        <Setter Property="Padding"              Value="6,4"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource OD.Border.InputHover}"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource OD.Accent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Background"           Value="{StaticResource OD.Bg.Input}"/>
        <Setter Property="Foreground"           Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush"          Value="{StaticResource OD.Border.Input}"/>
        <Setter Property="BorderThickness"      Value="1"/>
        <Setter Property="Padding"              Value="6,4"/>
    </Style>

    <Style TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Background"           Value="{StaticResource OD.Bg.Input}"/>
        <Setter Property="Foreground"           Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Padding"              Value="6,4"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{StaticResource OD.Selection}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Label — default Foreground is SystemColors.ControlText (near-black) -->
    <Style TargetType="{x:Type Label}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
    </Style>

    <!-- TextBlock — already inherits Foreground from parent in most cases,
         but stand-alone TextBlocks at window root sometimes don't reach the
         inherited value when wrapped in transparent layout panels. Pinning
         it explicitly is harmless. -->
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
    </Style>

    <!-- GroupBox header -->
    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Input}"/>
    </Style>

    <!-- CheckBox / RadioButton -->
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Background" Value="{StaticResource OD.Bg.Input}"/>
    </Style>
    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Background" Value="{StaticResource OD.Bg.Input}"/>
    </Style>

    <!-- DataGrid headers (the common "white text on white header" complaint) -->
    <Style TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background" Value="#FF2A2A2A"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Input}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <Style TargetType="{x:Type DataGridRowHeader}">
        <Setter Property="Background" Value="#FF2A2A2A"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
    </Style>

    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource OD.Selection}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ListBox / ListBoxItem — used by some report dialogs -->
    <Style TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Input}"/>
    </Style>
    <Style TargetType="{x:Type ListBoxItem}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Padding" Value="6,3"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource OD.Selection}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- TabControl / TabItem — Settings dialog and any future tabbed UI -->
    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Input}"/>
    </Style>
    <Style TargetType="{x:Type TabItem}">
        <Setter Property="Background" Value="#FF222222"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Padding" Value="10,4"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource OD.Bg.InputHover}"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- MenuItem — Settings/help context menus on MainShellView -->
    <Style TargetType="{x:Type Menu}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
    </Style>
    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
    </Style>
</ResourceDictionary>
