<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:OrderDeck.App.Controls">
    <!--
        Modern minimalist dark theme.

        Design principles:
        - Surfaces are flat with no hard borders. Hierarchy comes from
          subtle background lifts (1A → 22 → 2A) and 4-6 px corner radius.
        - Hover/active states use a quiet 6 % lift rather than a bright
          accent — the accent (#3B82F6) is reserved for primary actions
          and focus rings.
        - Text is slightly off-white (#EDEDED) so long sessions don't
          burn the eyes.
        - All interactive surfaces share consistent radius (4 for inputs,
          6 for cards/menus) and padding, so the visual rhythm holds.
    -->

    <!-- ── Palette ──────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="OD.Bg.Window"          Color="#FF161616"/>
    <SolidColorBrush x:Key="OD.Bg.Surface"         Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="OD.Bg.Elevated"        Color="#FF222222"/>
    <SolidColorBrush x:Key="OD.Bg.Input"           Color="#FF1F1F1F"/>
    <SolidColorBrush x:Key="OD.Bg.InputHover"      Color="#FF2A2A2A"/>
    <SolidColorBrush x:Key="OD.Bg.InputPressed"    Color="#FF333333"/>
    <SolidColorBrush x:Key="OD.Bg.InputDisabled"   Color="#FF1B1B1B"/>

    <SolidColorBrush x:Key="OD.Border.Subtle"      Color="#FF2E2E2E"/>
    <SolidColorBrush x:Key="OD.Border.Hover"       Color="#FF3A3A3A"/>
    <SolidColorBrush x:Key="OD.Border.Focus"       Color="#FF3B82F6"/>

    <SolidColorBrush x:Key="OD.Fg.Primary"         Color="#FFEDEDED"/>
    <SolidColorBrush x:Key="OD.Fg.Secondary"       Color="#FF9E9E9E"/>
    <SolidColorBrush x:Key="OD.Fg.Disabled"        Color="#FF5A5A5A"/>

    <SolidColorBrush x:Key="OD.Accent"             Color="#FF3B82F6"/>
    <SolidColorBrush x:Key="OD.Accent.Hover"       Color="#FF4F8EF7"/>
    <SolidColorBrush x:Key="OD.Accent.Pressed"     Color="#FF2563EB"/>
    <SolidColorBrush x:Key="OD.Selection"          Color="#FF2A3F5C"/>

    <!-- Drop shadow shared across menus and tooltips. -->
    <DropShadowEffect x:Key="OD.Shadow.Soft"
                      BlurRadius="14" ShadowDepth="3" Opacity="0.45"
                      Direction="270" Color="Black"/>

    <!-- ── Window — every Window in the app inherits the dark surface +
         primary text. AccountDialog (and any future dialog that forgets
         to set Background/Foreground) was the failure mode: TextBlocks
         set to OD.Fg.Primary rendered on Windows 11's light system bg
         = unreadable. -->
    <Style TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Window}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
    </Style>

    <!-- ── Button — flat, rounded, hover lift ──────────────────────────── -->
    <Style TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Input}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="MinWidth" Value="72"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Bg.InputHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Bg.InputPressed}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource OD.Border.Focus}"/>
                        </Trigger>
                        <Trigger Property="IsDefault" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Accent}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsDefault" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Accent.Hover}"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsDefault" Value="True"/>
                                <Condition Property="IsPressed" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Accent.Pressed}"/>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Bg.InputDisabled}"/>
                            <Setter Property="Foreground" Value="{StaticResource OD.Fg.Disabled}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── TextBox / PasswordBox ───────────────────────────────────────── -->
    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Input}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="CaretBrush" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource OD.Selection}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource OD.Border.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource OD.Border.Focus}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Bg.InputDisabled}"/>
                            <Setter Property="Foreground" Value="{StaticResource OD.Fg.Disabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type PasswordBox}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Input}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="CaretBrush" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource OD.Selection}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="MinHeight" Value="30"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Hover}"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Focus}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── ComboBox — full template so the dropdown popup stays dark ────── -->
    <ControlTemplate x:Key="OD.ComboBoxToggleButtonTemplate" TargetType="{x:Type ToggleButton}">
        <Border x:Name="Bd"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="4"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Path Grid.Column="1"
                      Data="M 0,0 L 4,4 L 8,0 Z"
                      Fill="{StaticResource OD.Fg.Secondary}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource OD.Border.Hover}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource OD.Border.Focus}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Input}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      Template="{StaticResource OD.ComboBoxToggleButtonTemplate}"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"/>
                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border x:Name="DropDownBorder"
                                    Background="{StaticResource OD.Bg.Elevated}"
                                    BorderBrush="{StaticResource OD.Border.Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    SnapsToDevicePixels="True"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Margin="0,4,0,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.45"
                                                      Direction="270" Color="Black"/>
                                </Border.Effect>
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="{StaticResource OD.Bg.InputDisabled}"/>
                            <Setter Property="Foreground" Value="{StaticResource OD.Fg.Disabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="3"
                            Margin="2,1"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Bg.InputHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Selection}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Text containers ─────────────────────────────────────────────── -->
    <Style TargetType="{x:Type Label}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Padding" Value="0,2"/>
    </Style>
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
    </Style>
    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ── Toggles ─────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Background" Value="{StaticResource OD.Bg.Input}"/>
    </Style>
    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Background" Value="{StaticResource OD.Bg.Input}"/>
    </Style>

    <!-- ── DataGrid ────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Elevated}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Secondary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>
    <Style TargetType="{x:Type DataGridRowHeader}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Elevated}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
    </Style>
    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Padding" Value="6,3"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource OD.Selection}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── ListBox ─────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style TargetType="{x:Type ListBoxItem}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Padding" Value="8,5"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource OD.Bg.InputHover}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource OD.Selection}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Tabs — full template so the content panel stays dark.
         Default Aero TabControl renders an inner ContentPresenter chrome
         with SystemColors.WindowBrush (white), which is what made TextBoxes
         on the "Yazıcı" tab look light-on-light despite the input style
         being correct. -->
    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                BorderBrush="{StaticResource OD.Border.Subtle}"
                                BorderThickness="0,0,0,1">
                            <TabPanel x:Name="HeaderPanel"
                                      IsItemsHost="True"
                                      Panel.ZIndex="1"
                                      KeyboardNavigation.TabIndex="1"/>
                        </Border>
                        <Border Grid.Row="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                KeyboardNavigation.TabNavigation="Local"
                                KeyboardNavigation.DirectionalNavigation="Contained"
                                KeyboardNavigation.TabIndex="2">
                            <ContentPresenter ContentSource="SelectedContent"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type TabItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Secondary}"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Margin" Value="0,0,2,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="0,0,0,2"
                            CornerRadius="4,4,0,0"
                            SnapsToDevicePixels="True">
                        <ContentPresenter ContentSource="Header"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Bg.InputHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Bg.Elevated}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource OD.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Menus ───────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type Menu}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
    </Style>
    <!-- ContextMenu — full template so the default Aero "icon column"
         (a 28 px white strip on the left edge that holds checkmark/icon
         placeholders for every MenuItem) doesn't render. Replaced with
         a flat StackPanel ItemsHost. The thin white vertical line in the
         three-dot menu screenshot was that strip. -->
    <Style TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Elevated}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True"
                                    KeyboardNavigation.DirectionalNavigation="Cycle"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- MenuItem template — no icon/check gutter (the white strip that
         appeared in the three-dot menu earlier) and no extra outer Margin
         (which combined with the popup's Padding caused the items to
         clip first 1-2 chars on the left when the popup auto-sized).

         Layout: ContentPresenter for Header in a single column, with
         left-padding handled by the Border's Padding (NOT the
         ContentPresenter's Margin) so the popup's measure pass sees the
         full width including padding and sizes the popup correctly. -->
    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0"
                                              ContentSource="Header"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{TemplateBinding InputGestureText}"
                                       Foreground="{StaticResource OD.Fg.Secondary}"
                                       VerticalAlignment="Center"
                                       Margin="14,0,0,0"/>
                            <Path x:Name="SubmenuArrow"
                                  Grid.Column="2"
                                  Visibility="Collapsed"
                                  Data="M 0,0 L 4,4 L 0,8 Z"
                                  Fill="{StaticResource OD.Fg.Secondary}"
                                  VerticalAlignment="Center"
                                  Margin="14,0,0,0"/>
                            <Popup x:Name="PART_Popup"
                                   Placement="Right"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource OD.Bg.Elevated}"
                                        BorderBrush="{StaticResource OD.Border.Subtle}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="4">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.45"
                                                          Direction="270" Color="Black"/>
                                    </Border.Effect>
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Bg.InputHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource OD.Fg.Disabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Custom controls derived from Button — implicit-style match by type
         only catches the EXACT type, so derived classes need an explicit
         style entry. ShortcutCaptureButton lives in OrderDeck.App.Controls
         and inherits everything from the Button style above. -->
    <Style TargetType="{x:Type controls:ShortcutCaptureButton}"
           BasedOn="{StaticResource {x:Type Button}}">
        <!-- Slightly lighter font + monospace digits so chord text reads cleanly. -->
        <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style TargetType="{x:Type Separator}">
        <Setter Property="Background" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="Margin" Value="6,4"/>
        <Setter Property="Height" Value="1"/>
    </Style>

    <!-- ── ToolTip ─────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Elevated}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
