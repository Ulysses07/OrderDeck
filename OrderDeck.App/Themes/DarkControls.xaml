<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Modern minimalist dark theme.

        Design principles:
        - Surfaces are flat with no hard borders. Hierarchy comes from
          subtle background lifts (1A → 22 → 2A) and 4-6 px corner radius.
        - Hover/active states use a quiet 6 % lift rather than a bright
          accent — the accent (#3B82F6) is reserved for primary actions
          and focus rings.
        - Text is slightly off-white (#EDEDED) so long sessions don't
          burn the eyes.
        - All interactive surfaces share consistent radius (4 for inputs,
          6 for cards/menus) and padding, so the visual rhythm holds.
    -->

    <!-- ── Palette ──────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="OD.Bg.Window"          Color="#FF161616"/>
    <SolidColorBrush x:Key="OD.Bg.Surface"         Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="OD.Bg.Elevated"        Color="#FF222222"/>
    <SolidColorBrush x:Key="OD.Bg.Input"           Color="#FF1F1F1F"/>
    <SolidColorBrush x:Key="OD.Bg.InputHover"      Color="#FF2A2A2A"/>
    <SolidColorBrush x:Key="OD.Bg.InputPressed"    Color="#FF333333"/>
    <SolidColorBrush x:Key="OD.Bg.InputDisabled"   Color="#FF1B1B1B"/>

    <SolidColorBrush x:Key="OD.Border.Subtle"      Color="#FF2E2E2E"/>
    <SolidColorBrush x:Key="OD.Border.Hover"       Color="#FF3A3A3A"/>
    <SolidColorBrush x:Key="OD.Border.Focus"       Color="#FF3B82F6"/>

    <SolidColorBrush x:Key="OD.Fg.Primary"         Color="#FFEDEDED"/>
    <SolidColorBrush x:Key="OD.Fg.Secondary"       Color="#FF9E9E9E"/>
    <SolidColorBrush x:Key="OD.Fg.Disabled"        Color="#FF5A5A5A"/>

    <SolidColorBrush x:Key="OD.Accent"             Color="#FF3B82F6"/>
    <SolidColorBrush x:Key="OD.Accent.Hover"       Color="#FF4F8EF7"/>
    <SolidColorBrush x:Key="OD.Accent.Pressed"     Color="#FF2563EB"/>
    <SolidColorBrush x:Key="OD.Selection"          Color="#FF2A3F5C"/>

    <!-- Drop shadow shared across menus and tooltips. -->
    <DropShadowEffect x:Key="OD.Shadow.Soft"
                      BlurRadius="14" ShadowDepth="3" Opacity="0.45"
                      Direction="270" Color="Black"/>

    <!-- ── Button — flat, rounded, hover lift ──────────────────────────── -->
    <Style TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Input}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="MinWidth" Value="72"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Bg.InputHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Bg.InputPressed}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource OD.Border.Focus}"/>
                        </Trigger>
                        <Trigger Property="IsDefault" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Accent}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsDefault" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Accent.Hover}"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsDefault" Value="True"/>
                                <Condition Property="IsPressed" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Accent.Pressed}"/>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Bg.InputDisabled}"/>
                            <Setter Property="Foreground" Value="{StaticResource OD.Fg.Disabled}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── TextBox / PasswordBox ───────────────────────────────────────── -->
    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Input}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="CaretBrush" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource OD.Selection}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource OD.Border.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource OD.Border.Focus}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource OD.Bg.InputDisabled}"/>
                            <Setter Property="Foreground" Value="{StaticResource OD.Fg.Disabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type PasswordBox}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Input}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="CaretBrush" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource OD.Selection}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="MinHeight" Value="30"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Hover}"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Focus}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── ComboBox ────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Input}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="MinHeight" Value="30"/>
    </Style>
    <Style TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Padding" Value="8,6"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{StaticResource OD.Bg.InputHover}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource OD.Selection}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Text containers ─────────────────────────────────────────────── -->
    <Style TargetType="{x:Type Label}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Padding" Value="0,2"/>
    </Style>
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
    </Style>
    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ── Toggles ─────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Background" Value="{StaticResource OD.Bg.Input}"/>
    </Style>
    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Background" Value="{StaticResource OD.Bg.Input}"/>
    </Style>

    <!-- ── DataGrid ────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Elevated}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Secondary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>
    <Style TargetType="{x:Type DataGridRowHeader}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Elevated}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
    </Style>
    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Padding" Value="6,3"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource OD.Selection}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── ListBox ─────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style TargetType="{x:Type ListBoxItem}">
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Padding" Value="8,5"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource OD.Bg.InputHover}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource OD.Selection}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Tabs ────────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>
    <Style TargetType="{x:Type TabItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Secondary}"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Margin" Value="0,0,2,0"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource OD.Bg.Elevated}"/>
                <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Menus ───────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type Menu}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
    </Style>
    <Style TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Elevated}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="HasDropShadow" Value="True"/>
    </Style>
    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="Padding" Value="12,6"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{StaticResource OD.Bg.InputHover}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource OD.Fg.Disabled}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="{x:Type Separator}">
        <Setter Property="Background" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="Margin" Value="6,4"/>
        <Setter Property="Height" Value="1"/>
    </Style>

    <!-- ── ToolTip ─────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="Background" Value="{StaticResource OD.Bg.Elevated}"/>
        <Setter Property="Foreground" Value="{StaticResource OD.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OD.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="HasDropShadow" Value="True"/>
    </Style>
</ResourceDictionary>
