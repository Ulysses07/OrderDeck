<UserControl x:Class="OrderDeck.App.Controls.AnimationPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OrderDeck.App.Converters"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             Background="Transparent" Foreground="White">
  <UserControl.Resources>
    <conv:EqualityToBrushConverter x:Key="EqToBrush"/>
  </UserControl.Resources>
  <!--
    UniformGrid Columns=2: each card stretches to fill its half of the row,
    so there's no dead space on the right. Card height auto-grows with
    content and UniformGrid syncs heights across the row, which is fine
    because every card has the same template (image + name + desc + buttons).
  -->
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <ItemsControl ItemsSource="{Binding Animations}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <UniformGrid Columns="2"/>
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <!--
            Border highlight: gold when this card's Id matches the picker's
            SelectedId, transparent otherwise. Compared via MultiBinding +
            EqualityToBrushConverter because DataTrigger.Value is not a
            DependencyProperty and cannot accept a Binding directly.
          -->
          <Border Margin="4" CornerRadius="8" BorderThickness="2"
                  Background="#FF1F2937"
                  ClipToBounds="True"
                  MouseEnter="Card_MouseEnter"
                  MouseLeave="Card_MouseLeave">
            <Border.BorderBrush>
              <MultiBinding Converter="{StaticResource EqToBrush}"
                            ConverterParameter="#FFFFCE46|Transparent">
                <Binding Path="Id"/>
                <Binding Path="DataContext.SelectedId"
                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
              </MultiBinding>
            </Border.BorderBrush>
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Visual -->
                <RowDefinition Height="*"/>      <!-- Body -->
              </Grid.RowDefinitions>
              <!--
                Visual at top, fills the full card width, fixed height for
                UniformGrid row-height sync. SvgViewbox (SharpVectors) is used
                because the WPF Image control only renders raster formats —
                animation thumbnails are authored as SVG so the same asset
                works in the /overlay/preview web view.
              -->
              <Border Grid.Row="0" Background="#FF0F1118" Height="130">
                <svgc:SvgViewbox Source="{Binding ThumbnailUri}"
                                 Stretch="UniformToFill"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"/>
              </Border>
              <!-- Body: name + description + actions -->
              <StackPanel Grid.Row="1" Margin="10,8,10,10">
                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"
                           Margin="0,0,0,2" Foreground="White"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Description}" FontSize="11"
                           Foreground="#FFB0B0B0" TextWrapping="Wrap"
                           MaxHeight="32" TextTrimming="CharacterEllipsis"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                  <Button Content="Seç" Width="64" Margin="0,0,6,0"
                          CommandParameter="{Binding Id}"
                          Click="SelectButton_Click"/>
                  <Button Content="Önizle" Width="72"
                          CommandParameter="{Binding Id}"
                          Click="PreviewButton_Click"/>
                </StackPanel>
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </ScrollViewer>
</UserControl>
