<UserControl x:Class="OrderDeck.App.Controls.AnimationPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OrderDeck.App.Converters"
             Background="Transparent" Foreground="White">
  <UserControl.Resources>
    <conv:EqualityToBrushConverter x:Key="EqToBrush"/>
  </UserControl.Resources>
  <ItemsControl ItemsSource="{Binding Animations}">
    <ItemsControl.ItemsPanel>
      <ItemsPanelTemplate>
        <UniformGrid Columns="3"/>
      </ItemsPanelTemplate>
    </ItemsControl.ItemsPanel>
    <ItemsControl.ItemTemplate>
      <DataTemplate>
        <!--
          Border highlight: gold when this card's Id matches the picker's
          SelectedId, transparent otherwise. Compared via MultiBinding +
          EqualityToBrushConverter because DataTrigger.Value is not a
          DependencyProperty and cannot accept a Binding directly.
        -->
        <Border Margin="6" Padding="6" CornerRadius="6" BorderThickness="2"
                Background="#FF1F2937">
          <Border.BorderBrush>
            <MultiBinding Converter="{StaticResource EqToBrush}"
                          ConverterParameter="#FFFFCE46|Transparent">
              <Binding Path="Id"/>
              <Binding Path="DataContext.SelectedId"
                       RelativeSource="{RelativeSource AncestorType=UserControl}"/>
            </MultiBinding>
          </Border.BorderBrush>
          <StackPanel>
            <Image Source="{Binding ThumbnailUri}"
                   Width="180" Height="120" Stretch="UniformToFill"/>
            <TextBlock Text="{Binding Name}" FontWeight="Bold"
                       Margin="0,6,0,2" Foreground="White"/>
            <TextBlock Text="{Binding Description}" FontSize="11"
                       Foreground="#FFB0B0B0" TextWrapping="Wrap"/>
            <Button Content="Seç" Margin="0,6,0,0"
                    CommandParameter="{Binding Id}"
                    Click="SelectButton_Click"/>
          </StackPanel>
        </Border>
      </DataTemplate>
    </ItemsControl.ItemTemplate>
  </ItemsControl>
</UserControl>
