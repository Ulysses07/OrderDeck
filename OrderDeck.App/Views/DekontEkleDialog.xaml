<Window x:Class="OrderDeck.App.Views.DekontEkleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:OrderDeck.App.Converters"
        Title="Yeni Dekont" Width="500" Height="540"
        WindowStartupLocation="CenterOwner"
        Background="#FF1A1A1A" Foreground="White">
    <Window.Resources>
        <converters:NullToCollapsedConverter x:Key="NullToCollapsed"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: PDF button -->
            <RowDefinition Height="Auto"/>  <!-- 1: Ödeyen -->
            <RowDefinition Height="Auto"/>  <!-- 2: Tutar -->
            <RowDefinition Height="Auto"/>  <!-- 3: Tarih -->
            <RowDefinition Height="Auto"/>  <!-- 4: Referans -->
            <RowDefinition Height="Auto"/>  <!-- 5: Müşteri header -->
            <RowDefinition Height="Auto"/>  <!-- 6: Platform -->
            <RowDefinition Height="Auto"/>  <!-- 7: Username -->
            <RowDefinition Height="Auto"/>  <!-- 8: Error -->
            <RowDefinition Height="*"/>     <!-- 9: spacer -->
            <RowDefinition Height="Auto"/>  <!-- 10: Buttons -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Row="0" Grid.ColumnSpan="2"
                Content="📄 PDF Yükle (alanları otomatik doldur)"
                Click="OnPickPdf"
                HorizontalAlignment="Stretch"
                Padding="14,8" Margin="0,0,0,12"
                Background="#FF2A2A2A" Foreground="White"
                BorderBrush="#FF3A3A3A"
                ToolTip="Banka dekontu PDF'inden ödeyen, tutar, tarih ve referans no'yu otomatik çıkarır. Yanlış çıkarsa elle düzeltebilirsin."/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Ödeyen:" Margin="0,8,8,8" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="1" Grid.Column="1"
                   Text="{Binding PayerName, UpdateSourceTrigger=PropertyChanged}"
                   Padding="6" Margin="0,4"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Tutar (TL):" Margin="0,8,8,8" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="2" Grid.Column="1"
                   Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                   Padding="6" Margin="0,4"
                   ToolTip="Örn: 250,50 veya 250.50"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Ödeme tarihi:" Margin="0,8,8,8" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="3" Grid.Column="1"
                    SelectedDate="{Binding PaidAt}"
                    Margin="0,4"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Referans no:" Margin="0,8,8,8" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="4" Grid.Column="1"
                   Text="{Binding ReferansNo, UpdateSourceTrigger=PropertyChanged}"
                   Padding="6" Margin="0,4"
                   ToolTip="Banka dekontundaki referans/işlem no"/>

        <TextBlock Grid.Row="5" Grid.ColumnSpan="2" Text="Müşteri (opsiyonel — kargo eşleştirme için)"
                   FontSize="11" Foreground="#FFAAAAAA" Margin="0,16,0,4"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Platform:" Margin="0,8,8,8" VerticalAlignment="Center"/>
        <ComboBox  Grid.Row="6" Grid.Column="1"
                   SelectedValue="{Binding CustomerPlatform}"
                   SelectedValuePath="Content"
                   Margin="0,4"
                   ToolTip="Müşterinin yayın platformu — kargo eşleştirme için">
            <ComboBoxItem Content=""/>
            <ComboBoxItem Content="instagram"/>
            <ComboBoxItem Content="tiktok"/>
            <ComboBoxItem Content="facebook"/>
            <ComboBoxItem Content="youtube"/>
            <ComboBoxItem Content="form"/>
        </ComboBox>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Kullanıcı adı:" Margin="0,8,8,8" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="7" Grid.Column="1"
                   Text="{Binding CustomerUsername, UpdateSourceTrigger=PropertyChanged}"
                   Padding="6" Margin="0,4"
                   ToolTip="Müşterinin platformdaki kullanıcı adı (örn: @ayse_y) — bulunursa otomatik eşleştirme yapılır"/>

        <TextBlock Grid.Row="8" Grid.ColumnSpan="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="#FFFF6B6B"
                   TextWrapping="Wrap"
                   Margin="0,12,0,0"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}"/>

        <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="İptal" Click="OnCancel" Padding="14,6" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Kaydet"
                    Click="OnSave"
                    Padding="14,6"
                    IsEnabled="{Binding CanSave}"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
