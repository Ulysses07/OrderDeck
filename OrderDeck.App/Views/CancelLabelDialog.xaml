<Window x:Class="OrderDeck.App.Views.CancelLabelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Etiket İptali"
        Width="380" Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="İptal Sebebi"
                   FontSize="16" FontWeight="Bold"
                   Foreground="#FFEDEDED"
                   Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1"
                   Text="Bu etiketleri neden iptal ediyorsun?"
                   Foreground="#FF9E9E9E"
                   FontSize="11"
                   Margin="0,0,0,16"/>

        <StackPanel Grid.Row="2">
            <RadioButton x:Name="ReasonCustomer"     GroupName="Reason"
                         Content="Müşteri vazgeçti"
                         Margin="0,4" IsChecked="True"/>
            <RadioButton x:Name="ReasonWrongProduct" GroupName="Reason"
                         Content="Yanlış ürün / fiyat"
                         Margin="0,4"/>
            <RadioButton x:Name="ReasonDuplicate"    GroupName="Reason"
                         Content="Mükerrer kayıt"
                         Margin="0,4"/>
            <RadioButton x:Name="ReasonOutOfStock"   GroupName="Reason"
                         Content="Stok kalmadı"
                         Margin="0,4"/>
            <RadioButton x:Name="ReasonCustom"       GroupName="Reason"
                         Content="Özel sebep"
                         Margin="0,4"/>
            <TextBox x:Name="CustomReasonText"
                     Margin="22,4,0,0"
                     IsEnabled="{Binding IsChecked, ElementName=ReasonCustom}"
                     MaxLength="120"
                     ToolTip="Özel sebebi yaz"/>
        </StackPanel>

        <TextBlock Grid.Row="3"
                   x:Name="WarningText"
                   Foreground="#FFEF4444"
                   FontSize="11"
                   Visibility="Collapsed"
                   Margin="0,8,0,0"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Vazgeç" Padding="14,7" Margin="0,0,8,0"
                    Click="OnCancel" IsCancel="True"/>
            <Button Content="İptal Et" Padding="14,7"
                    Click="OnConfirm" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
