{
    # Force Let's Encrypt production (avoid staging fallback after early DNS failures)
    acme_ca https://acme-v02.api.letsencrypt.org/directory
}

(security_headers) {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }
}

license.orderdeckapp.com {
    import security_headers
    encode gzip

    # Block public access to internal observability endpoints (Phase 5e).
    # /metrics (Prometheus scrape) and the Hangfire dashboard should only be
    # reachable from a tunnelled SSH session or a private monitoring host.
    # Add monitoring CIDR(s) to the allowlist when standing up Grafana/Prometheus.
    @internal_paths path /metrics* /hangfire*
    @internal_blocked {
        path /metrics* /hangfire*
        not remote_ip 127.0.0.1/32 ::1/128
    }
    respond @internal_blocked "Not Found" 404 {
        close
    }

    reverse_proxy license-server:8080
}

# ─── Marketing site (orderdeckapp.com apex + www) ────────────────────────────
# Statik export Next.js build çıktısı /srv/web altına bind-mount edilmiş.
# `npm run build` → `web/out/` üretiyor → rsync ile VPS'teki /opt/orderdeck/web-out
# klasörüne kopyalanıyor → docker-compose volume olarak Caddy container'ına
# bağlanmış. Caddy file_server klasör hash'i değişince otomatik servis ediyor;
# restart gerekmiyor.
www.orderdeckapp.com {
    import security_headers
    redir https://orderdeckapp.com{uri} permanent
}

orderdeckapp.com {
    import security_headers
    encode gzip zstd

    # Brotli'i enable etmek için xcaddy build gerekiyor — şimdilik gzip+zstd yeterli.

    # Statik dosyalara uzun cache; HTML sayfalara kısa (deploy sonrası anında güncellenmesi için).
    @static path *.css *.js *.svg *.png *.jpg *.jpeg *.webp *.woff2 *.ico
    header @static Cache-Control "public, max-age=31536000, immutable"

    @html path *.html /
    header @html Cache-Control "public, max-age=300, must-revalidate"

    # Trailing slash davranışı: Next.js trailingSlash:true ile her route bir
    # klasör + index.html üretiyor; file_server bunu doğal olarak handle ediyor.
    root * /srv/web
    file_server {
        # Klasik 404 sayfasını Next.js'in oluşturduğu out/404.html ile değiştir.
        # (Next App Router not-found.tsx → 404.html üretiyor.)
        precompressed gzip
    }

    # 404 fallback — yoksa default Caddy 404'ü çıksın, /404/ gibi rotaları kırma.
    handle_errors {
        @404 expression {http.error.status_code} == 404
        rewrite @404 /404.html
        file_server
    }
}
